#!/usr/bin/env bash

set -eufo pipefail

{{ $brews := list
    "bash"
    "bat"
    "cloc"
    "coreutils"
    "fd"
    "fzf"
    "ghostscript"
    "git"
    "git-delta"
    "git-filter-repo"
    "git-lfs"
    "gnutls"
    "go"
    "imagemagick"
    "iperf"
    "jq"
    "libraw"
    "mtr"
    "ncdu"
    "nmap"
    "nvm"
    "parallel"
    "pinentry"
    "rsync"
    "shellcheck"
    "shfmt"
    "speedtest-cli"
    "subversion"
    "tree"
    "watch"
    "wget"
    "xmlstarlet"
    "yamllint"
    "yarn"
    "yq"
    "zsh-completions"
-}}

{{ $casks := list
    "1password-cli"
    "1password"
    "alfred"
    "alcove"
    "arc"
    "bartender"
    "betterdisplay"
    "bettertouchtool"
    "chatgpt"
    "claude"
    "coconutbattery"
    "codex-app"
    "disk-inventory-x"
    "docker-desktop"
    "fantastical"
    "firefox"
    "git-credential-manager"
    "github"
    "gpg-suite"
    "google-chrome"
    "home-assistant"
    "istat-menus"
    "iterm2"
    "jetbrains-toolbox"
    "logi-options+"
    "okta-verify"
    "pearcleaner"
    "sf-symbols"
    "shottr"
    "sourcetree"
    "sublime-text"
    "the-unarchiver"
    "visual-studio-code"
-}}

{{ if .work -}}
export HOMEBREW_GITHUB_ADOBE_API_TOKEN={{ onepasswordRead "op://Adobe/Homebrew GitHub Adobe Token/credential" | trim }}
brew tap "adobe-marketing-cloud/brews"
brew tap "argoproj/tap"
brew tap "azure/kubelogin"
brew tap "experience-platform/internal" "git@git.corp.adobe.com:experience-platform/homebrew-internal.git"
brew tap "foundation/foundation" "git@git.corp.adobe.com:foundation/homebrew-foundation.git"

{{ $brews = concat $brews (list
    "adobe-marketing-cloud/brews/repo"
    "argoproj/tap/kubectl-argo-rollouts"
    "azure-cli"
    "experience-platform/internal/cmcli"
    "experience-platform/internal/skyline-ops-cli"
    "ffmpeg"
    "helm"
    "k9s"
    "maven-completion"
    "opa"
    "wsk"
) -}}

{{ $casks = concat $casks (list
    "cursor"
    "slack"
) -}}

if [[ ! "$(command -v claude)" ]]; then
    curl -fsSL https://claude.ai/install.sh | bash
fi

{{ end -}}

brewfile="$(mktemp -t brewfile.XXXXXXXXXX)"
trap 'rm -f "$brewfile"' EXIT

# Ensure interactive prompts (e.g. sudo password) can read from a real terminal.
if [[ ! -r /dev/tty ]]; then
  echo "No TTY available for sudo prompts. Run 'sudo -v' first, then rerun chezmoi apply." >&2
  exit 1
fi


cat >"$brewfile" <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
EOF

brew bundle --file="$brewfile"

mkdir -p "$HOME/.nvm"

if command -v brew >/dev/null 2>&1; then
  nvm_prefix="$(brew --prefix nvm 2>/dev/null || true)"
  if [[ -n "$nvm_prefix" && -s "${nvm_prefix}/nvm.sh" ]]; then
    # shellcheck source=/dev/null
    . "${nvm_prefix}/nvm.sh"
  fi
fi

if command -v nvm >/dev/null 2>&1; then
  nvm install --lts
  nvm alias default 'lts/*'
else
  echo "nvm is installed but not available in this shell; skipping Node LTS install." >&2
fi

casks=(
{{- range ($casks | sortAlpha | uniq) }}
  "{{ . }}"
{{- end }}
)

brew install --force --cask "${casks[@]}"
