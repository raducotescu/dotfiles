#!/usr/bin/env bash

set -euo pipefail

detect_login_shell() {
{{- if eq .chezmoi.os "darwin" }}
  if command -v dscl >/dev/null 2>&1; then
    dscl . -read "/Users/${USER}" UserShell 2>/dev/null | awk '{print $2}'
    return
  fi
{{- else if eq .chezmoi.os "linux" }}

  if command -v getent >/dev/null 2>&1; then
    getent passwd "${USER}" | cut -d: -f7
    return
  fi
{{- end }}

  printf '%s\n' "${SHELL:-}"
}

current_shell="$(detect_login_shell)"
zsh_path="$(command -v zsh || true)"

if [[ -z "${zsh_path}" ]]; then
  echo "zsh is not installed; skipping default shell update." >&2
  exit 0
fi

if [[ "${current_shell}" == "${zsh_path}" ]]; then
  echo "Login shell already set to zsh (${zsh_path})."
  exit 0
fi

if [[ -r /etc/shells ]] && ! grep -Fxq "${zsh_path}" /etc/shells; then
  echo "zsh path (${zsh_path}) is not listed in /etc/shells; skipping shell change." >&2
  echo "Add it to /etc/shells and rerun chezmoi apply." >&2
  exit 0
fi

if ! command -v chsh >/dev/null 2>&1; then
  echo "chsh is not available; cannot change login shell automatically." >&2
  exit 0
fi

if [[ ! -r /dev/tty ]]; then
  echo "No TTY available for chsh prompt. Run this manually:" >&2
  echo "  chsh -s ${zsh_path}" >&2
  exit 0
fi

echo "Changing login shell from '${current_shell:-unknown}' to '${zsh_path}'."
chsh -s "${zsh_path}" "${USER}" < /dev/tty
