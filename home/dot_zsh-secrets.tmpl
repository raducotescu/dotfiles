{{- if and (eq .chezmoi.os "darwin") .work -}}
export CHEZMOI_GITHUB_ACCESS_TOKEN={{ onepasswordRead "op://Adobe/Github Basic API Access/credential" | trim }}
export HOMEBREW_GITHUB_ADOBE_API_TOKEN={{ onepasswordRead "op://Adobe/Homebrew GitHub Adobe Token/credential" | trim }}
export HOMEBREW_ARTIFACTORY_TOKEN={{ onepasswordRead "op://Adobe/Homebrew Artifactory Token/credential" | trim }}
export ARTIFACTORY_API_TOKEN={{ onepasswordRead "op://Adobe/Artifactory API Token/credential" | trim }}
export ARTIFACTORY_USER="cotescu"
export ARTIFACTORY_NPM_USERNAME="${ARTIFACTORY_USER}"
export ARTIFACTORY_NPM_PASSWORD="$( printf '%s' "$ARTIFACTORY_API_TOKEN" | base64 )"
{{- end -}}
